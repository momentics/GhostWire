#include <winver.h>

1 ICON "@GHOSTWIRE_RC_ICON_PATH@"
1 24 "app.manifest"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @GhostWireDesktop_VERSION_MAJOR@,@GhostWireDesktop_VERSION_MINOR@,@GhostWireDesktop_VERSION_PATCH@,0
 PRODUCTVERSION @GhostWireDesktop_VERSION_MAJOR@,@GhostWireDesktop_VERSION_MINOR@,@GhostWireDesktop_VERSION_PATCH@,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName", "@GHOSTWIRE_COMPANY_NAME@\0"
            VALUE "FileDescription", "@GHOSTWIRE_FILE_DESCRIPTION@\0"
            VALUE "FileVersion", "@GHOSTWIRE_MANIFEST_VERSION@\0"
            VALUE "InternalName", "@GHOSTWIRE_INTERNAL_NAME@\0"
            VALUE "LegalCopyright", "@GHOSTWIRE_COPYRIGHT@\0"
            VALUE "OriginalFilename", "@GHOSTWIRE_ORIGINAL_FILENAME@\0"
            VALUE "ProductName", "@GHOSTWIRE_PRODUCT_NAME@\0"
            VALUE "ProductVersion", "@GHOSTWIRE_MANIFEST_VERSION@\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
